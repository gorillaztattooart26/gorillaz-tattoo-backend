# Supabase — get these from your project dashboard:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PayMongo — get these from https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=
# From Developers -> Webhooks -> [endpoint] -> Signing secret (only exists
# once a webhook endpoint is registered against a deployed URL)
PAYMONGO_WEBHOOK_SECRET=

# Supabase service role key — Dashboard -> Settings -> API -> service_role
# secret. Server-only, bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — get this from https://resend.com/api-keys. Server-only.
RESEND_API_KEY=
# onboarding@resend.dev until a domain is verified in Resend.
RESEND_FROM_EMAIL=
# Where the staff "new inquiry" notification is sent.
STAFF_NOTIFICATION_EMAIL=
